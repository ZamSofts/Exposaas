{
  "name": "exposaas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"NEXT,WORKER,WS\" -c \"blue,green,yellow\" \"next dev\" \"node -r dotenv/config extra/workers/vehicle.mjs\" \"node -r dotenv/config extra/webSocket/ws.mjs\" \"node -r dotenv/config extra/workers/invoice.mjs\" ",
    "worker": "node -r dotenv/config extra/workers/vehicle.mjs",
    "ws": "node -r dotenv/config extra/webSocket/ws.mjs",
    "build": "next build",
    "start": "concurrently -n \"NEXT,WORKER,WS\" -c \"blue,green,yellow\" \"next start -p 3001 -H 0.0.0.0\" \"node -r dotenv/config extra/workers/vehicle.mjs\" \"node -r dotenv/config extra/webSocket/ws.mjs\" \"node -r dotenv/config extra/workers/invoice.mjs\"",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/core": "^0.34.2",
    "@azure/storage-blob": "^12.28.0",
    "@cyntler/react-doc-viewer": "^1.17.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.13.0",
    "csv-parser": "^3.2.0",
    "lucide-react": "^0.539.0",
    "multer": "^2.0.2",
    "next": "15.4.4",
    "next-auth": "^4.24.11",
    "pg": "^8.16.3",
    "pg-boss": "^11.0.8",
    "prisma": "^6.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-select": "^5.10.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.4.4",
    "tailwindcss": "^4"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
