generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        Int           @id @default(autoincrement())
  name      String
  createdAt DateTime      @default(now())
  status    CompanyStatus @default(active)
  users     User[]
  vehicles  Vehicle[]
  roles     Role[]
  paymentConfirmations PaymentConfirmation[]
  InvoiceJobs   InvoiceJobs[]
  customers Customer[]
  promptVersions PromptVersion[]
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  country   String?
  uniqueId  String
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    Int?      @unique
  user      User?     @relation(fields: [userId], references: [id])
  companyId Int?
  company   Company?   @relation(fields: [companyId], references: [id])

  @@unique([companyId, uniqueId])
  @@index([companyId])
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  password     String
  companyId    Int
  createdAt    DateTime      @default(now())
  company      Company       @relation(fields: [companyId], references: [id])
  roles        UserRole[]
  customer     Customer?

  @@index([companyId])
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String
  permissions RolePermission[]
  users       UserRole[]
  companyId   Int?
  company     Company?         @relation(fields: [companyId], references: [id])

  @@unique([name, companyId])
  @@map("Role")
}

model Permission {
  id    Int              @id @default(autoincrement())
  name  String           @unique
  roles RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  role   Role @relation(fields: [roleId], references: [id])
  user   User @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
}

model Vehicle {
  id            Int           @id @default(autoincrement())
  name          String?
  chassisNumber String
  remarks       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  companyId     Int
  brandId       Int
  customerId    Int?
  auction       String?
  lotNumber     String?

  // Charge columns (acquisition costs from invoices/CSV)
  bidAmount          Decimal?  @db.Decimal(12, 2)
  auctionFee         Decimal?  @db.Decimal(12, 2)
  insuranceFee       Decimal?  @db.Decimal(12, 2)
  recyclingFee       Decimal?  @db.Decimal(12, 2)
  transportFee       Decimal?  @db.Decimal(12, 2)
  otherFees          Decimal?  @db.Decimal(12, 2)
  taxSum             Decimal?  @db.Decimal(12, 2)  // Auto-calculated: (bid + auction + insurance + transport + other) × 0.1
  totalCost          Decimal?  @db.Decimal(12, 2)  // Auto-calculated: all fees + taxSum
  sourceInvoiceJobId Int?

  // Logistics/metadata columns
  auctionDate            String?
  session                String?
  transportCompany       String?
  deliverTo              String?
  numberPlate            String?
  titleTransferDeadline  DateTime?
  containerNumber        String?
  etd                    String?
  documentStatus         String?
  memo                   String?

  // Size dimensions (from certificates: export_cert, inspection_cert, temp_cancel)
  length    Int?              // cm
  width     Int?              // cm
  height    Int?              // cm
  m3        Decimal?  @db.Decimal(8, 2)  // cubic meters (L×W×H ÷ 1,000,000)

  // Relations
  brand         Brand         @relation(fields: [brandId], references: [id])
  company       Company       @relation(fields: [companyId], references: [id])
  customer      Customer?     @relation(fields: [customerId], references: [id])
  sourceInvoiceJob InvoiceJobs? @relation(fields: [sourceInvoiceJobId], references: [id])
  documents     VehicleDocument[]
  payments      VehiclePayments[]

  @@unique([companyId, chassisNumber])
  @@index([companyId])
  @@index([sourceInvoiceJobId])
  @@index([brandId])
  @@index([customerId])
}

model VehicleDocument {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  Url       String
  docType   String?  // invoice, export_cert, inspection_cert, temp_cancel
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model VehiclePayments {
  id        Int       @id @default(autoincrement())
  vehicleId Int
  name      String
  amount    Decimal   @db.Decimal(10, 2)
  date      DateTime?
  remarks   String?
  url       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Brand {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  vehicles Vehicle[]
}


model PaymentConfirmation {
  id          Int      @id @default(autoincrement())
  DocumentURL String?  
  Page        Int      
  Json        Json     
  isCorrect   String
  diffSummary  Json?
  auctionHouse String?
  isGolden     Boolean  @default(false)
  invoiceJobId Int?
  companyId   Int
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([companyId, auctionHouse])
  @@index([invoiceJobId])
}

model InvoiceJobs {
  id          Int      @id @default(autoincrement())
  DocumentURL String?
  Json        Json?    // Extraction result for this page
  companyId   Int
  isEvaluated Boolean   @default(false)
  status      String   @default("pending")  // pending, processing, completed, failed, empty, needs_classification
  totalPages  Int?     // Total page count in PDF (legacy, kept for backwards compat)
  docType     String   @default("invoice")  // invoice, export_cert, inspection_cert, temp_cancel, unknown

  // Per-page job fields (new architecture)
  pageNumber          Int?      // Which page this is (1, 2, 3...) - null for legacy jobs
  parentDocumentUrl   String?   // Original multi-page PDF URL (to group pages from same upload)
  originalTotalPages  Int?      // Total pages in original PDF

  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  vehicles    Vehicle[]  // Vehicles created from this invoice

  @@index([companyId])
  @@index([companyId, docType])
  @@index([parentDocumentUrl])  // For grouping pages from same PDF
}


model PromptVersion {
  id           Int       @id @default(autoincrement())
  version      String
  content      String    @db.Text
  parentId     Int?
  strategy     String?
  status       String    @default("draft") // draft, evaluating, evaluated, active, archived
  score        Float?
  scoreDetails Json?
  companyId    Int
  createdAt    DateTime  @default(now())
  evaluatedAt  DateTime?

  company  Company        @relation(fields: [companyId], references: [id])
  parent   PromptVersion? @relation("PromptDeriv", fields: [parentId], references: [id])
  children PromptVersion[] @relation("PromptDeriv")

  @@index([companyId])
  @@index([companyId, status])
}

enum CompanyStatus {
  active
  inactive
}
