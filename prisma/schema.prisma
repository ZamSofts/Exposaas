generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   Int                   @id @default(autoincrement())
  name                 String
  createdAt            DateTime              @default(now())
  status               CompanyStatus         @default(active)
  customers            Customer[]
  exportTemplates      ExportTemplate[]
  gmailAccount         GmailAccount?
  InvoiceJobs          InvoiceJobs[]
  auctionInvoices      AuctionInvoice[]
  paymentConfirmations PaymentConfirmation[]
  promptVersions       PromptVersion[]
  roles                Role[]
  users                User[]
  vehicles             Vehicle[]
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  country   String?
  uniqueId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    Int?      @unique
  companyId Int?
  company   Company?  @relation(fields: [companyId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])
  vehicles  Vehicle[]

  @@unique([companyId, uniqueId])
  @@index([companyId])
}

model User {
  id                Int                @id @default(autoincrement())
  username          String             @unique
  password          String
  companyId         Int
  createdAt         DateTime           @default(now())
  customer          Customer?
  company           Company            @relation(fields: [companyId], references: [id])
  roles             UserRole[]
  transportRequests TransportRequest[]

  @@index([companyId])
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String
  companyId   Int?
  company     Company?         @relation(fields: [companyId], references: [id])
  permissions RolePermission[]
  users       UserRole[]

  @@unique([name, companyId])
  @@map("Role")
}

model Permission {
  id    Int              @id @default(autoincrement())
  name  String           @unique
  roles RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  role   Role @relation(fields: [roleId], references: [id])
  user   User @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
}

model Vehicle {
  id                    Int               @id @default(autoincrement())
  name                  String?
  chassisNumber         String
  remarks               String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  companyId             Int
  brandId               Int
  auction               String?
  lotNumber             String?
  customerId            Int?
  auctionFee            Decimal?          @db.Decimal(12, 2)
  bidAmount             Decimal?          @db.Decimal(12, 2)
  otherFees             Decimal?          @db.Decimal(12, 2)
  recyclingFee          Decimal?          @db.Decimal(12, 2)
  sourceInvoiceJobId    Int?
  totalCost             Decimal?          @db.Decimal(12, 2)
  transportFee          Decimal?          @db.Decimal(12, 2)
  auctionDate           String?
  containerNumber       String?
  deliverTo             String?
  etd                   String?
  numberPlate           String?
  session               String?
  taxSum                Decimal?          @db.Decimal(12, 2)
  titleTransferDeadline DateTime?
  transportCompany      String?
  insuranceFee          Decimal?          @db.Decimal(12, 2)
  documentStatus        String?
  memo                  String?
  height                Int?
  length                Int?
  m3                    Decimal?          @db.Decimal(8, 2)
  width                 Int?
  engineModel           String?
  vehicleWeight         Int?
  grossVehicleWeight    Int?
  engineDisplacement    Int?
  firstRegistrationDate String?
  createdById           Int?
  updatedById           Int?
  mergedAt              DateTime?
  mergedFields          Json?
  mergedFromId          Int?
  brand                 Brand             @relation(fields: [brandId], references: [id])
  company               Company           @relation(fields: [companyId], references: [id])
  customer              Customer?         @relation(fields: [customerId], references: [id])
  sourceInvoiceJob      InvoiceJobs?      @relation(fields: [sourceInvoiceJobId], references: [id])
  auctionInvoiceId      Int?
  auctionInvoice        AuctionInvoice?   @relation(fields: [auctionInvoiceId], references: [id])
  extractionDeadline    DateTime?
  auditLogs             VehicleAuditLog[]
  documents             VehicleDocument[]
  payments              VehiclePayments[]
  transportRequests     TransportRequest[]

  @@unique([companyId, chassisNumber])
  @@index([companyId])
  @@index([companyId, lotNumber, auction])
  @@index([sourceInvoiceJobId])
  @@index([brandId])
  @@index([customerId])
}

model VehicleDocument {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Url       String
  docType   String?
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model VehiclePayments {
  id        Int       @id @default(autoincrement())
  vehicleId Int
  name      String
  date      DateTime?
  amount    Decimal   @db.Decimal(10, 2)
  remarks   String?
  url       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Brand {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  vehicles Vehicle[]
}

model PaymentConfirmation {
  id           Int          @id @default(autoincrement())
  DocumentURL  String?
  Page         Int
  Json         Json
  isCorrect    String
  companyId    Int
  createdAt    DateTime     @default(now())
  invoiceJobId Int?
  auctionHouse String?
  diffSummary  Json?
  isGolden     Boolean      @default(false)
  embedding    Json?
  reviewedById Int?
  company      Company      @relation(fields: [companyId], references: [id])
  invoiceJob   InvoiceJobs? @relation("PaymentConfirmationInvoiceJob", fields: [invoiceJobId], references: [id])

  @@index([companyId])
  @@index([companyId, auctionHouse])
  @@index([companyId, isGolden])
  @@index([invoiceJobId])
}

model InvoiceJobs {
  id                   Int                   @id @default(autoincrement())
  DocumentURL          String?
  Json                 Json?
  companyId            Int
  createdAt            DateTime              @default(now())
  isEvaluated          Boolean               @default(false)
  status               JobStatus             @default(pending)
  totalPages           Int?
  originalTotalPages   Int?
  pageNumber           Int?
  parentDocumentUrl    String?
  docType              String                @default("invoice")
  invoiceTotal         Int?
  sessionNumber        String?
  auctionInvoiceId     Int?
  company              Company               @relation(fields: [companyId], references: [id])
  auctionInvoice       AuctionInvoice?       @relation(fields: [auctionInvoiceId], references: [id])
  paymentConfirmations PaymentConfirmation[] @relation("PaymentConfirmationInvoiceJob")
  vehicles             Vehicle[]

  @@index([companyId])
  @@index([companyId, docType])
  @@index([parentDocumentUrl])
  @@index([auctionInvoiceId])
}

model AuctionInvoice {
  id                Int               @id @default(autoincrement())
  companyId         Int
  parentDocumentUrl String?
  auctionVenue      String?
  auctionDate       DateTime?
  sessionNumber     String?
  invoiceTotal      Int?
  paymentDueDate    DateTime?
  isPaid                Boolean           @default(false)
  isPrepaymentRequired  Boolean           @default(false)
  status                String            @default("pending")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  company           Company           @relation(fields: [companyId], references: [id])
  invoiceJobs       InvoiceJobs[]
  vehicles          Vehicle[]

  @@index([companyId])
  @@index([parentDocumentUrl])
}

model TransportRequest {
  id               Int       @id @default(autoincrement())
  vehicleId        Int
  transportCompany String
  requestedById    Int
  requestedAt      DateTime  @default(now())
  completedAt      DateTime?
  destination      String?
  status           String    @default("pending")
  notes            String?
  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id])
  requestedBy      User      @relation(fields: [requestedById], references: [id])

  @@index([vehicleId])
  @@index([requestedById])
}

model PromptVersion {
  id           Int             @id @default(autoincrement())
  version      String
  content      String
  parentId     Int?
  strategy     String?
  status       String          @default("draft")
  score        Float?
  scoreDetails Json?
  companyId    Int
  createdAt    DateTime        @default(now())
  evaluatedAt  DateTime?
  company      Company         @relation(fields: [companyId], references: [id])
  parent       PromptVersion?  @relation("PromptDeriv", fields: [parentId], references: [id])
  children     PromptVersion[] @relation("PromptDeriv")

  @@index([companyId])
  @@index([companyId, status])
}

model VehicleAuditLog {
  id        Int      @id @default(autoincrement())
  vehicleId Int?
  action    String
  actor     String
  actorId   String?
  field     String?
  oldValue  String?
  newValue  String?
  source    String?
  metadata  Json?
  createdAt DateTime @default(now())
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([vehicleId, createdAt])
}

model ExportTemplate {
  id                  Int      @id @default(autoincrement())
  name                String
  companyId           Int
  createdById         Int?
  columns             Json
  computedColumns     Json     @default("[]")
  footerRows          Json     @default("[]")
  showContainerNumber Boolean  @default(true)
  showDate            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  company             Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
}

model GmailAccount {
  id            Int            @id @default(autoincrement())
  companyId     Int            @unique
  email         String
  refreshToken  String
  lastHistoryId String?
  ussPassword   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  emails        EmailMessage[]
  company       Company        @relation(fields: [companyId], references: [id])
}

model EmailMessage {
  id             Int          @id @default(autoincrement())
  gmailAccountId Int
  gmailMessageId String
  subject        String?
  fromAddress    String?
  receivedAt     DateTime?
  attachmentUrl  String?
  status         String       @default("pending")
  skipReason     String?
  documentJobId  Int?
  createdAt      DateTime     @default(now())
  gmailAccount   GmailAccount @relation(fields: [gmailAccountId], references: [id])

  @@unique([gmailAccountId, gmailMessageId])
  @@index([gmailAccountId])
  @@index([status])
}

enum CompanyStatus {
  active
  inactive
}

enum JobStatus {
  pending
  processing
  completed
  failed
  empty
  needs_classification
}
