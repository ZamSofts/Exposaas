# ============================================
# Exposaas Environment Variables
# Copy this file to .env (local) or .env.docker (production)
# ============================================

# --- Required ---

# NextAuth session secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/exposaas?schema=public"

# Google Gemini API key (for PDF extraction)
GEMINI_API_KEY=

# Azure Blob Storage (for PDF file storage)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=

# --- WebSocket ---

# Public WebSocket URL (change to server IP/domain in production)
NEXT_PUBLIC_WS_URL="ws://localhost:5000"

# --- Optional ---

# WebSocket server config
# WS_PORT=5000
# MAX_WS_CONNECTIONS=1000
# MAX_MESSAGE_LENGTH=5000

# Redis (only if using Redis features)
# REDIS_URL=
