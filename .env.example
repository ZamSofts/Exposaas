# ============================================
# Exposaas Environment Variables
# Copy this file to .env (local) or .env.docker (production)
# ============================================

# --- Required ---

# NextAuth session secret (required — generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Superadmin credentials (required for Sadmin login bypass)
SADMIN_USERNAME=
SADMIN_PASSWORD=

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/exposaas?schema=public"

# Google Gemini API key (for PDF extraction)
GEMINI_API_KEY=

# Azure Blob Storage (for PDF file storage)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=

# Gmail OAuth2 (for email auto-ingestion)
# Obtain from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback
